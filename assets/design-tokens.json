{
  "$meta": {
    "brand": "Play (play.pl)",
    "source": "https://www.play.pl",
    "extractedAt": "2026-07-14",
    "method": "Computed styles extracted from the live homepage via Playwright"
  },
  "colors": {
    "brand": {
      "primary": "#6C43BF",
      "primaryDark": "#2D0066",
      "accent": "#E6144B",
      "link": "#266DD9"
    },
    "background": {
      "default": "#FFFFFF",
      "light": "#F5F5F5",
      "subtle": "#FAFAFA",
      "overlay": "rgba(255, 255, 255, 0.9)"
    },
    "text": {
      "primary": "#1F1F1F",
      "secondary": "#404040",
      "muted": "#707070",
      "onDark": "#FFFFFF",
      "onBrand": "#FFFFFF"
    },
    "border": {
      "default": "#D6D6D6"
    }
  },
  "typography": {
    "fontFamily": {
      "primary": "\"Manrope\", Arial, sans-serif"
    },
    "fontFaces": [
      { "family": "Manrope", "weight": 500, "src": "https://media-play.pl/binaries/web/fonts/Manrope-Regular.woff2" },
      { "family": "Manrope", "weight": 600, "src": "https://media-play.pl/binaries/web/fonts/Manrope-SemiBold.woff2" },
      { "family": "Manrope", "weight": 700, "src": "https://media-play.pl/binaries/web/fonts/Manrope-Bold.woff2" }
    ],
    "fontWeights": {
      "regular": 500,
      "semibold": 600,
      "bold": 700
    },
    "fontSize": {
      "xs": "10.5px",
      "sm": "12.25px",
      "base": "14px",
      "lg": "21px",
      "xl": "40px"
    },
    "lineHeight": {
      "tight": "1.3",
      "base": "1.5"
    }
  },
  "spacing": {
    "comment": "Play uses a 7px base unit (fractional px values like 3.5, 10.5, 21 appear throughout)",
    "1": "3.5px",
    "2": "7px",
    "3": "10.5px",
    "4": "14px",
    "5": "21px",
    "6": "28px",
    "7": "35px",
    "8": "42px"
  },
  "borderRadius": {
    "xs": "3.5px",
    "sm": "5px",
    "md": "7px",
    "lg": "10.5px",
    "xl": "12px",
    "2xl": "14px",
    "circle": "50%"
  },
  "components": {
    "button": {
      "primary": {
        "backgroundColor": "#6C43BF",
        "color": "#FFFFFF",
        "padding": "0 21px",
        "borderRadius": "7px",
        "fontSize": "14px",
        "fontWeight": 500,
        "border": "none"
      },
      "secondary": {
        "backgroundColor": "#FFFFFF",
        "color": "#6C43BF",
        "padding": "0 21px",
        "borderRadius": "7px",
        "fontSize": "14px",
        "fontWeight": 500,
        "border": "none"
      },
      "iconCircle": {
        "backgroundColor": "#FFFFFF",
        "color": "#000000",
        "borderRadius": "50%",
        "border": "0.8px solid #D6D6D6"
      }
    },
    "header": {
      "backgroundColor": "transparent",
      "color": "#1F1F1F",
      "fontSize": "14px",
      "fontWeight": 500
    },
    "nav": {
      "color": "#1F1F1F",
      "activeColor": "#6C43BF",
      "fontSize": "10.5px",
      "fontWeight": 500,
      "activeFontWeight": 700,
      "textTransform": "none"
    },
    "body": {
      "backgroundColor": "#FFFFFF",
      "color": "#1F1F1F",
      "fontSize": "14px",
      "fontWeight": 500,
      "lineHeight": "21px"
    },
    "headings": {
      "h2": { "fontSize": "40px", "fontWeight": 500, "lineHeight": "60px", "color": "#1F1F1F" },
      "h3": { "fontSize": "21px", "fontWeight": 500, "lineHeight": "27.3px", "color": "#1F1F1F" }
    },
    "promo": {
      "backgroundColor": "#E6144B",
      "color": "#FFFFFF"
    },
    "carouselBullet": {
      "backgroundColor": "#6C43BF",
      "borderRadius": "5px"
    }
  }
}
